<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox spacing="20"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="projects.workshop1project.Controllers.HospitalController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Text text="Hospital Check-in">
            <font>
                <Font name="Tahoma" size="28"/>
            </font>
        </Text>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="backBtn" text="Back" onAction="#handleBack" prefWidth="90" focusTraversable="false"/>
    </HBox>

    <GridPane hgap="10" vgap="10">

        <Label text="Full Name:"     GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameFld"   GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="220"/>

        <Label text="Date of Birth:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <DatePicker fx:id="dobPck"   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Gender:"        GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <HBox spacing="25"           GridPane.columnIndex="1" GridPane.rowIndex="2">
            <RadioButton fx:id="maleRB"   text="Male"   selected="true"/>
            <RadioButton fx:id="femaleRB" text="Female"/>
        </HBox>

        <Label text="Triage:"            GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ChoiceBox fx:id="triageChoice"  GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Phone:"         GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="phoneFld"  GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="220"/>

        <Label text="National ID:"   GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="idFld"     GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="220"/>

        <Label text="Doctor:"         GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="doctorFld"  GridPane.columnIndex="1" GridPane.rowIndex="6" prefWidth="220"/>

        <Label text="Symptoms:"        GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <TextField fx:id="symptomsFld" GridPane.columnIndex="1" GridPane.rowIndex="7" prefWidth="220"/>

    </GridPane>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button fx:id="createBtn"  text="Create"  onAction="#handleCreate"  prefWidth="100" focusTraversable="false"/>
        <Button fx:id="updateBtn"  text="Update"  onAction="#handleUpdate"  prefWidth="100" focusTraversable="false"/>
        <Button fx:id="deleteBtn"  text="Delete"  onAction="#handleDelete"  prefWidth="100" focusTraversable="false"/>
        <Button fx:id="clearBtn"   text="Clear"   onAction="#handleClear"   prefWidth="100" focusTraversable="false"/>
        <Button fx:id="summaryBtn" text="Summary" onAction="#handleSummary" prefWidth="100" focusTraversable="false"/>
        <Text fx:id="msgTxt"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName"     text="Full Name"   minWidth="130"/>
            <TableColumn fx:id="colDob"      text="DOB"         minWidth="110"/>
            <TableColumn fx:id="colGender"   text="Gender"      minWidth="80"/>
            <TableColumn fx:id="colTriage"   text="Triage"      minWidth="80"/>
            <TableColumn fx:id="colPhone"    text="Phone"       minWidth="110"/>
            <TableColumn fx:id="colId"       text="National ID" minWidth="110"/>
            <TableColumn fx:id="colDoctor"   text="Doctor"      minWidth="110"/>
            <TableColumn fx:id="colSymptoms" text="Symptoms"    minWidth="150"/>
        </columns>
        <placeholder>
            <Label text="No patient records yet. Use the form above to add one."/>
        </placeholder>
    </TableView>

</VBox>
